{
  "name": "clipster",
  "version": "0.1.0",
  "builtin-baseline": "f87344cac03158cbf1467264565f1fd36b382a24",
  "description": "Lightweight background game replay buffer - clip the last N seconds on a hotkey",
  "dependencies": [
    "nlohmann-json",
    {
      "name": "qtbase",
      "platform": "windows"
    },
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample",
        "swscale",
        "openh264",
        {
          "name": "nvcodec",
          "platform": "windows | linux"
        },
        {
          "name": "amf",
          "platform": "windows"
        }
      ]
    }
  ]
}
